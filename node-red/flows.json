    {
        "id": "n_alert",
        "type": "function",
        "z": "t_main",
        "name": "Alerte JSON invalide",
        "func": "node.warn('Message rejeté: ' + msg.error);\nconst parts = (msg.topic || '').split('/');\nconst grp = parts[1] || 'g1';\nconst dev = parts[2] || 'unknown';\nmsg.topic = 'campus/' + grp + '/' + dev + '/alerts';\nmsg.qos = 1;\nmsg.payload = JSON.stringify({ error: msg.error, ts: Date.now() });\nreturn msg;\n",
        "outputs": 1,
