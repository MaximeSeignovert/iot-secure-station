    {
        "id": "n_mqttin",
        "type": "mqtt in",
        "z": "t_main",
        "name": "campus/+/+/data",
        "topic": "campus/+/+/data",
        "qos": "1",
        "datatype": "auto-detect",
        "broker": "b1",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 140,
        "y": 120,
        "wires": [
            [
                "n_valid"
            ]
        ]
    },
    {
        "id": "n_valid",
        "type": "function",
        "z": "t_main",
        "name": "Valider & router",
        "func": "let data;\ntry {\n    data = (typeof msg.payload === 'string') ? JSON.parse(msg.payload) : msg.payload;\n} catch (e) {\n    msg.error = 'JSON illisible';\n    return [null, msg];\n}\n\n// Schéma imposé : { device, ts, data:{...} }\nif (typeof data !== 'object' || data === null ||\n    typeof data.device !== 'string' ||\n    typeof data.ts !== 'number' ||\n    typeof data.data !== 'object' || data.data === null) {\n    msg.error = 'Schéma invalide';\n    msg.payload = data;\n    return [null, msg];\n}\n\n// Champs numériques uniquement\nconst fields = {};\nfor (const k in data.data) {\n    if (typeof data.data[k] === 'number' && isFinite(data.data[k])) {\n        fields[k] = data.data[k];\n    }\n}\nif (Object.keys(fields).length === 0) {\n    msg.error = 'Aucune mesure numérique';\n    return [null, msg];\n}\n\n// Timestamp d'origine -> rejeu offline correct.\n// On distingue une vraie date epoch d'un compteur millis() (boot ESP32 sans NTP).\nlet tsMs;\nif (data.ts >= 1e12) {\n    tsMs = data.ts;            // millisecondes epoch\n} else if (data.ts >= 1e9) {\n    tsMs = data.ts * 1000;     // secondes epoch -> ms\n} else {\n    tsMs = Date.now();         // ts non horodate (millis/boot) -> heure serveur\n}\n\nmsg.device = data.device;\nmsg.parsed = data;\nmsg.payload = [{\n    measurement: 'sensors',\n    fields: fields,\n    tags: { device: data.device },\n    timestamp: new Date(tsMs)\n}];\nreturn [msg, null];\n",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 120,
        "wires": [
            [
                "n_influx",
                "n_uitemp",
                "n_uihum",
                "n_uitext"
            ],
            [
                "n_alert",
                "n_dbg"
            ]
        ]
    },
    {
        "id": "n_influx",
        "type": "influxdb batch",
        "z": "t_main",
        "influxdb": "i1",
        "precision": "ms",
        "retentionPolicy": "",
        "name": "InfluxDB iot",
        "database": "database",
        "precisionV18FluxV20": "ms",
        "retentionPolicyV18Flux": "",
        "org": "organisation",
        "bucket": "bucket",
        "x": 600,
        "y": 80,
        "wires": []
    },
    {
        "id": "n_uitemp",
        "type": "function",
        "z": "t_main",
        "name": "temp",
        "func": "if (!msg.parsed || typeof msg.parsed.data.temp !== 'number') return null;\nmsg.payload = msg.parsed.data.temp;\nmsg.topic = 'Température';\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 160,
